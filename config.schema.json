{
  "pluginAlias": "CBus",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Clipsal C-Gate"
      },
      "client_ip_address": {
        "title": "C-Gate Host",
        "type": "string",
        "default": "127.0.0.1",
        "required": true
      },
      "client_controlport": {
        "title": "C-Gate Control Port",
        "type": "integer",
        "default": 20023,
        "required": true
      },
      "client_cbusname": {
        "title": "C-Bus Project Name",
        "type": "string",
        "required": true
      },
      "client_network": {
        "title": "C-Bus Network",
        "type": "integer",
        "default": 254,
        "required": true
      },
      "client_application": {
        "title": "C-Bus Application",
        "type": "integer",
        "default": 56,
        "required": true
      },
      "client_debug": {
        "title": "Enable C-Gate Debug Logging",
        "type": "boolean",
        "default": false
      },
      "autoDiscover": {
        "title": "Enable Auto Discovery",
        "type": "boolean",
        "default": true
      },
      "discoveryDefaultType": {
        "title": "Default Type for Discovered Groups",
        "type": "string",
        "default": "light",
        "oneOf": [
          { "title": "Light", "enum": ["light"] },
          { "title": "Dimmer", "enum": ["dimmer"] },
          { "title": "Switch", "enum": ["switch"] },
          { "title": "Fan", "enum": ["fan"] }
        ]
      },
      "discoveryCacheEnabled": {
        "title": "Write Discovery Cache on Startup",
        "type": "boolean",
        "default": true
      },
      "discoveryCachePath": {
        "title": "Discovery Cache Output Path",
        "type": "string",
        "default": "/volume1/DATA1/cbus-discovery-cache.json"
      },
      "platform_export": {
        "title": "Platform Export Path",
        "type": "string"
      },
      "database_export": {
        "title": "Database Export Path",
        "type": "string"
      }
    }
  },
  "layout": [
    { "key": "name" },
    { "key": "client_ip_address" },
    { "key": "client_controlport" },
    { "key": "client_cbusname" },
    { "key": "client_network" },
    { "key": "client_application" },
    { "key": "client_debug" },
    { "key": "autoDiscover" },
    { "key": "discoveryDefaultType" },
    { "key": "discoveryCacheEnabled" },
    { "key": "discoveryCachePath" },
    {
      "type": "advanced",
      "items": [
        "platform_export",
        "database_export"
      ]
    }
  ]
}