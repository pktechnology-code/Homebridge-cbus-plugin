{
  "pluginAlias": "CBus",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Clipsal C-Gate"
      },
      "client_ip_address": {
        "title": "C-Gate Host",
        "type": "string",
        "default": "127.0.0.1",
        "required": true,
        "description": "IP address or host name of the C-Gate server. Use 127.0.0.1 when C-Gate runs on the same machine as Homebridge."
      },
      "client_controlport": {
        "title": "C-Gate Control Port",
        "type": "integer",
        "default": 20023,
        "required": true
      },
      "client_cbusname": {
        "title": "C-Bus Project Name",
        "type": "string",
        "required": true,
        "description": "The C-Gate project name, for example MyHouse."
      },
      "client_network": {
        "title": "C-Bus Network",
        "type": "integer",
        "default": 254,
        "required": true
      },
      "client_application": {
        "title": "C-Bus Application",
        "type": "integer",
        "default": 56,
        "required": true
      },
      "client_debug": {
  "title": "Enable C-Gate Debug Logging",
  "type": "boolean",
  "default": false
},
"autoDiscover": {
  "title": "Enable Auto Discovery",
  "type": "boolean",
  "default": false,
  "description": "Discover C-Bus groups from C-Gate. Discovered groups are only added to HomeKit if their group IDs are listed in Include Discovered Group IDs."
},
"discoveryDefaultType": {
  "title": "Default Type for Discovered Groups",
  "type": "string",
  "default": "light",
  "oneOf": [
    { "title": "Light", "enum": ["light"] },
    { "title": "Dimmer", "enum": ["dimmer"] },
    { "title": "Switch", "enum": ["switch"] }
  ],
  "description": "Accessory type used for discovered groups unless manually configured."
},
"includeDiscoveredGroups": {
  "title": "Include Discovered Group IDs",
  "type": "array",
  "items": {
    "type": "string"
  },
  "default": [],
  "description": "Only discovered C-Bus group IDs listed here will be exposed to HomeKit, for example: 6, 71, 84."
},
"excludeDiscoveredGroups": {
  "title": "Exclude Discovered Group IDs",
  "type": "array",
  "items": {
    "type": "string"
  },
  "default": [],
  "description": "Optional list of discovered C-Bus group IDs to ignore."
},
"discoveryCacheEnabled": {
  "title": "Write Discovery Cache on Startup",
  "type": "boolean",
  "default": false,
  "description": "Writes a JSON file containing all discovered C-Bus groups from C-Gate. This does not add accessories to HomeKit."
},
"discoveryCachePath": {
  "title": "Discovery Cache Output Path",
  "type": "string",
  "default": "",
  "description": "Optional path for the discovery cache JSON file. Leave blank to write cbus-discovery-cache.json in the Homebridge working directory."
},
"platform_export": {
        "title": "Platform Export Path",
        "type": "string",
        "description": "Optional path to export generated platform JSON. Leave blank unless required."
      },
      "database_export": {
        "title": "Database Export Path",
        "type": "string",
        "description": "Optional path to export C-Gate database JSON. Leave blank unless required."
      },
      "accessories": {
        "title": "Accessories",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "type": {
              "title": "Type",
              "type": "string",
              "oneOf": [
                { "title": "Light", "enum": ["light"] },
                { "title": "Dimmer", "enum": ["dimmer"] },
                { "title": "Switch", "enum": ["switch"] },
                { "title": "Fan", "enum": ["fan"] },
                { "title": "Motion", "enum": ["motion"] },
                { "title": "Security", "enum": ["security"] },
                { "title": "Shutter", "enum": ["shutter"] },
                { "title": "Trigger", "enum": ["trigger"] },
                { "title": "Smoke", "enum": ["smoke"] },
                { "title": "Contact", "enum": ["contact"] },
                { "title": "Temperature", "enum": ["temperature"] }
              ],
              "required": true
            },
            "id": {
              "title": "Group Address / ID",
              "type": "string",
              "required": true
            },
            "name": {
              "title": "Accessory Name",
              "type": "string",
              "required": true
            },
            "enabled": {
              "title": "Enabled",
              "type": "boolean",
              "default": true
            },
            "network": {
              "title": "Network Override",
              "type": "integer"
            },
            "application": {
              "title": "Application Override",
              "type": "integer"
            },
            "channel": {
              "title": "Channel",
              "type": "integer"
            },
            "rampDuration": {
              "title": "Ramp Duration",
              "type": "string",
              "description": "Optional dimmer ramp time, e.g. 1s, 500ms, 2m."
            },
            "activeDuration": {
              "title": "Active Duration",
              "type": "string",
              "description": "Optional switch/trigger duration, e.g. 1 sec."
            }
          }
        },
        "default": []
      }
    }
  },
  "layout": [
    { "key": "name" },
    { "key": "client_ip_address" },
    { "key": "client_controlport" },
    { "key": "client_cbusname" },
    { "key": "client_network" },
    { "key": "client_application" },
    { "key": "client_debug" },
    { "key": "autoDiscover" },
    { "key": "discoveryDefaultType" },
    { "key": "includeDiscoveredGroups" },
    { "key": "excludeDiscoveredGroups" },
    { "key": "discoveryCacheEnabled" },
    { "key": "discoveryCachePath" },
    { "key": "accessories" },
    { "type": "advanced", "items": ["platform_export", "database_export"] }
  ]
}
