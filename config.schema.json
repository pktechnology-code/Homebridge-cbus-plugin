{
  "pluginAlias": "CBus",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Clipsal C-Gate"
      },
      "client_ip_address": {
        "title": "C-Gate Host",
        "type": "string",
        "default": "127.0.0.1",
        "required": true,
        "description": "IP address or host name of the C-Gate server. Use 127.0.0.1 when C-Gate runs on the same machine as Homebridge."
      },
      "client_controlport": {
        "title": "C-Gate Control Port",
        "type": "integer",
        "default": 20023,
        "required": true
      },
      "client_cbusname": {
        "title": "C-Bus Project Name",
        "type": "string",
        "minLength": 1,
        "maxLength": 8,
        "pattern": "^[A-Z0-9_]+$",
        "required": true,
        "description": "The C-Gate project name from Toolkit/C-Gate, for example MYHOUSE. This must be entered for your installation."
      },
      "client_network": {
        "title": "C-Bus Network",
        "type": "integer",
        "default": 254,
        "required": true
      },
      "client_application": {
        "title": "C-Bus Application",
        "type": "integer",
        "default": 56,
        "required": true
      },
      "client_debug": {
        "title": "Enable C-Gate Debug Logging",
        "type": "boolean",
        "default": false
      },
      "autoDiscover": {
        "title": "Enable Auto Discovery",
        "type": "boolean",
        "default": true
      },
      "discoveryDefaultType": {
        "title": "Default Type for Discovered Groups",
        "type": "string",
        "default": "light",
        "oneOf": [
          { "title": "Light", "enum": ["light"] },
          { "title": "Dimmer", "enum": ["dimmer"] },
          { "title": "Switch", "enum": ["switch"] },
          { "title": "Fan", "enum": ["fan"] }
        ]
      },
      "discoveryCacheEnabled": {
        "title": "Write Discovery Cache on Startup",
        "type": "boolean",
        "default": true
      },
      "discoveryCachePath": {
        "title": "Discovery Cache Output Path",
        "type": "string",
        "default": "",
        "description": "Optional full path for the discovery cache JSON file. Leave blank to use cbus-discovery-cache.json in the Homebridge storage folder, or enter a custom path."
      },
      "platform_export": {
        "title": "Platform Export Path",
        "type": "string"
      },
      "database_export": {
        "title": "Database Export Path",
        "type": "string"
      },
      "discoveredAccessories": {
        "title": "Discovered Accessories",
        "type": "array",
        "default": [],
        "items": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "type": {
              "type": "string"
            },
            "activeDuration": {
              "type": "string"
            },
            "network": {
              "type": "integer"
            },
            "application": {
              "type": "integer"
            },
            "channel": {
              "type": "integer"
            }
          }
        }
      },
      "accessories": {
        "title": "Legacy Accessories",
        "type": "array",
        "default": [],
        "items": {
          "type": "object"
        }
      }
    }
  },
  "layout": [
    { "key": "name" },
    { "key": "client_ip_address" },
    { "key": "client_controlport" },
    { "key": "client_cbusname" },
    { "key": "client_network" },
    { "key": "client_application" },
    { "key": "client_debug" },
    { "key": "autoDiscover" },
    { "key": "discoveryDefaultType" },
    { "key": "discoveryCacheEnabled" },
    { "key": "discoveryCachePath" },
    {
      "type": "advanced",
      "items": [
        "platform_export",
        "database_export"
      ]
    }
  ]
}
